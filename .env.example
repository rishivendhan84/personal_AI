# ============================================================================
# PAIOS environment. Copy to .env.local and fill in. Runs at $0/month.
# Every integration is env-gated: absent keys degrade gracefully, never crash.
# ============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# The single hardcoded user (matches supabase/migrations/0002_seed.sql).
PAIOS_USER_ID=00000000-0000-0000-0000-000000000001

# --- Supabase (Postgres + pgvector) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key: server-only, used by API routes/cron. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Telegram (capture transport) ---
TELEGRAM_BOT_TOKEN=
# Secret token validated on every webhook request (X-Telegram-Bot-Api-Secret-Token).
TELEGRAM_WEBHOOK_SECRET=

# --- AI providers: free primary, OpenAI fallback ---
# STT + cheap classify (Llama).
GROQ_API_KEY=
# Brief / Brain reasoning + canonical embeddings (text-embedding-004 = 768 dims).
GEMINI_API_KEY=
# Reliability fallback only — system never *requires* it.
OPENAI_API_KEY=

# Which provider answers. "auto" = free primary with OpenAI failover.
AI_STT_PRIMARY=groq
AI_LLM_PRIMARY=gemini
AI_EMBED_PRIMARY=gemini

# --- Scheduler + queue (Direction Engine + async capture) ---
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Google Calendar API (read-only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# --- Google Sheets API (finance source) ---
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Transactions!A:E
